# ============================================================
# AI Skills Platform - 生产环境配置模板
# ============================================================
# 使用说明：
# 1. 复制此文件内容到对应的 .env 文件
# 2. 修改标记为 [必改] 的配置项
# 3. 根据实际环境调整其他配置
# ============================================================


# ============================================================
# Portal Server 配置
# 文件位置: portal/server/.env
# ============================================================

# ---------- 环境 ----------
ENV=production
DEBUG=false

# ---------- 数据库 [必改] ----------
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_secure_password_here
DB_NAME=product_background

# ---------- AI 模型 [必改] ----------
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxx
ANTHROPIC_BASE_URL=
CLAUDE_MODEL=claude-opus-4-5

# ---------- CORS [必改] ----------
# 改为实际域名，支持多个域名
CORS_ORIGINS=["https://your-domain.com","https://www.your-domain.com"]

# ---------- 服务 URL ----------
ADMIN_API_URL=http://127.0.0.1:8001/api

# ---------- 存储路径（可选，默认在 server 目录下）----------
# OUTPUTS_DIR=/data/ai-platform/outputs
# UPLOADS_DIR=/data/ai-platform/uploads
# SKILLS_STORAGE_DIR=/data/ai-platform/skills_storage
# SKILLS_STORAGE_TEMP_DIR=/data/ai-platform/skills_storage_temp


# ============================================================
# Admin Server 配置
# 文件位置: admin/server/.env
# ============================================================

# ---------- 环境 ----------
# ENV=production
# DEBUG=false

# ---------- 数据库 [必改] (与 Portal 一致) ----------
# DB_HOST=localhost
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=your_secure_password_here
# DB_NAME=product_background

# ---------- JWT 认证 [必改] ----------
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_64_char_random_secret_key_here_generate_with_secrets
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ---------- CORS [必改] ----------
CORS_ORIGINS_STR=["https://your-domain.com","https://www.your-domain.com"]

# ---------- Portal API ----------
PORTAL_API_URL=http://127.0.0.1:8000/api

# ---------- Azure AI（可选）----------
# AZURE_API_KEY=your_azure_api_key


# ============================================================
# Docker Compose 配置
# 文件位置: .env (根目录)
# ============================================================

# ---------- 数据库 [必改] ----------
DB_ROOT_PASSWORD=your_mysql_root_password
DB_NAME=product_background

# ---------- API URL（Docker 内部）----------
PORTAL_API_URL=http://portal-api:8000/api
ADMIN_API_URL=http://admin-api:8000/api


# ============================================================
# 前端配置（通常不需要修改）
# ============================================================

# Portal Web (portal/web/.env.production)
# VITE_APP_TITLE=AI Skills Platform
# VITE_API_BASE_URL=/portal-api
# VITE_HOME_URL=/
# VITE_ADMIN_URL=/admin/

# Admin Web (admin/web/.env.production)
# VITE_APP_TITLE=AI Skills Admin
# VITE_API_BASE_URL=/admin-api
# VITE_PORTAL_URL=/portal/
# VITE_HOME_URL=/


# ============================================================
# 配置检查清单
# ============================================================
# [ ] DB_PASSWORD - 数据库密码（Portal + Admin）
# [ ] ANTHROPIC_API_KEY - Claude API 密钥
# [ ] SECRET_KEY - JWT 签名密钥（64字符随机串）
# [ ] CORS_ORIGINS - 前端域名白名单
# [ ] DB_ROOT_PASSWORD - MySQL root 密码（Docker）
# [ ] Nginx server_name - 实际域名
# [ ] SSL 证书配置（如需 HTTPS）
