# Portal Server - 配置模板
# 复制此文件为 .env 并修改配置值

# ========== 环境 ==========
ENV=development
DEBUG=true

# ========== 数据库 ==========
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=product_background

# ========== AI 模型 ==========
ANTHROPIC_API_KEY=your_api_key
ANTHROPIC_BASE_URL=
CLAUDE_MODEL=claude-opus-4-5

# ========== CORS ==========
# JSON 格式的域名列表 (portal:5173, admin:5174, home:5175)
CORS_ORIGINS=["http://localhost:5173","http://localhost:5174","http://localhost:5175"]

# ========== 服务 URL ==========
ADMIN_API_URL=http://localhost:8001/api
